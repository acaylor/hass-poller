# Copy this file to `.env` and fill in the values below.
# `docker compose` reads `.env` automatically.

# --- Home Assistant (required) -------------------------------------------

# Base URL of your Home Assistant instance, including scheme and port.
HA_BASE_URL=https://homeassistant.local:8123

# Long-lived access token. Create one at:
#   <HA URL> -> profile -> Security -> Long-lived access tokens
HA_TOKEN=

# --- TimescaleDB (required) ----------------------------------------------

# Credentials applied when the database container is first initialized.
# Change POSTGRES_PASSWORD before running `docker compose up` for the first
# time; once the volume is created, changing it here will NOT update the
# existing database user.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=warehouse

# --- Host port mappings (optional) ---------------------------------------

# Override these if 8080 / 8081 / 5432 are already in use on your host.
HTTP_PORT=8080
ADMINER_PORT=8081
POSTGRES_PORT=5432

# --- Poller behavior (optional) ------------------------------------------

# How often to poll Home Assistant. Any Go duration (e.g. 30s, 1m, 5m).
POLL_INTERVAL=1m

# Comma-separated glob patterns. An entity must match the allowlist AND
# must not match the blocklist to be ingested. See docs/ARCHITECTURE.md.
ENTITY_ALLOWLIST=sensor.*

# Examples of patterns worth excluding:
#   ENTITY_BLOCKLIST=sensor.*_signal_level,sensor.*_linkquality,sensor.energy_*
ENTITY_BLOCKLIST=

# Minimum absolute change required to write a new row. 0 means write on
# any change. Useful for damping floating-point jitter on noisy sensors.
EPSILON_DEFAULT=0

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
