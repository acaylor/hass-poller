flowchart TB
  main["cmd/ha-timescale-poller<br/>application composition"]
  config["internal/config<br/>env + YAML config"]
  schema["embedded schema.sql"]

  subgraph runtime["runtime components"]
    direction LR
    engine["internal/engine<br/>poll scheduler<br/>numeric parsing<br/>epsilon change detection"]
    httpServer["internal/httpserver<br/>/healthz<br/>/metrics"]
  end

  subgraph adapters["adapters"]
    direction LR
    haClient["internal/ha<br/>Home Assistant API client"]
    filter["internal/filter<br/>entity allowlist/blocklist"]
    store["internal/store<br/>pgxpool<br/>schema migration<br/>batch inserts"]
  end

  haApi["Home Assistant API<br/>/api/states"]
  database[("TimescaleDB<br/>ha_numeric<br/>ha_numeric_1h")]
  metrics["Prometheus registry<br/>poll, duration, rows, entity gauges"]

  main --> config
  main --> engine
  main --> httpServer
  main --> haClient
  main --> filter
  main --> store
  schema --> store

  engine -->|"fetch states"| haClient
  engine -->|"include/exclude entities"| filter
  engine -->|"write changed numeric values"| store
  engine -->|"update counters and gauges"| metrics

  httpServer -->|"last poll + DB health"| engine
  httpServer -->|"exposes metrics handler"| metrics

  haClient -->|"GET with bearer token"| haApi
  store -->|"CopyFrom + Ping"| database

  classDef entry fill:#e8f3ff,stroke:#2274a5,color:#111
  classDef runtime fill:#ffffff,stroke:#4f6f52,color:#111
  classDef adapter fill:#fff7e6,stroke:#b56b00,color:#111
  classDef boundary fill:#f7f7f7,stroke:#777,color:#111
  classDef data fill:#f3efe0,stroke:#927a28,color:#111

  class main,config,schema entry
  class engine,httpServer runtime
  class haClient,filter,store adapter
  class haApi,metrics boundary
  class database data
